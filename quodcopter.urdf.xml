<?xml version="1.0" ?>
<robot name="plus_quadcopter">
  
  <link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.04"/>
    </inertial>
    <visual>
      <geometry><box size="0.2 0.2 0.05"/></geometry>
      <material name="grey"><color rgba="0.6 0.6 0.6 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.2 0.2 0.05"/></geometry>
    </collision>
  </link>

  <link name="motor_front">
    <inertial><mass value="0.05"/><inertia ixx="0.0001" iyy="0.0001" izz="0.0001"/></inertial>
    <visual>
      <geometry><cylinder radius="0.08" length="0.01"/></geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
  </link>
  <joint name="j_front" type="fixed">
    <parent link="base_link"/><child link="motor_front"/>
    <origin xyz="0.15 0 0.025" rpy="0 0 0"/>
  </joint>

  <link name="motor_right">
    <inertial><mass value="0.05"/><inertia ixx="0.0001" iyy="0.0001" izz="0.0001"/></inertial>
    <visual>
      <geometry><cylinder radius="0.08" length="0.01"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>
  <joint name="j_right" type="fixed">
    <parent link="base_link"/><child link="motor_right"/>
    <origin xyz="0 -0.15 0.025" rpy="0 0 0"/>
  </joint>

  <link name="motor_back">
    <inertial><mass value="0.05"/><inertia ixx="0.0001" iyy="0.0001" izz="0.0001"/></inertial>
    <visual>
      <geometry><cylinder radius="0.08" length="0.01"/></geometry>
      <material name="black"><color rgba="0.2 0.2 0.2 1"/></material>
    </visual>
  </link>
  <joint name="j_back" type="fixed">
    <parent link="base_link"/><child link="motor_back"/>
    <origin xyz="-0.15 0 0.025" rpy="0 0 0"/>
  </joint>

  <link name="motor_left">
    <inertial><mass value="0.05"/><inertia ixx="0.0001" iyy="0.0001" izz="0.0001"/></inertial>
    <visual>
      <geometry><cylinder radius="0.08" length="0.01"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>
  <joint name="j_left" type="fixed">
    <parent link="base_link"/><child link="motor_left"/>
    <origin xyz="0 0.15 0.025" rpy="0 0 0"/>
  </joint>

</robot>